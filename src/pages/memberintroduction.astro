<!-- 以下ハンバーガーのjs -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("menuBtn");
    const menu = document.getElementById("menu");

    if (!btn || !menu) return;

    btn.addEventListener("click", () => {
      btn.classList.toggle("active");
      menu.classList.toggle("open");
    });
  });
</script>

<!-- トップに戻るボタン -->
<a href="#" class="to-top" id="toTop">▲</a>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<!-- JS -->
<script defer>
  window.addEventListener("DOMContentLoaded", () => {
    const swiper = new Swiper('.swiper', {
      loop: true,
      effect: 'fade',
      speed: 1000,
      autoplay: { delay: 3000 },
      pagination: { el: '.swiper-pagination', clickable: true },
    });
  });

  const toTop = document.getElementById("toTop");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 300) {
      toTop.classList.add("show");
    } else {
      toTop.classList.remove("show");
    }
  });
</script>

 <!-- 以下ハンバーガーのjs -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("menuBtn");
    const menu = document.getElementById("menu");

    if (!btn || !menu) return;

    btn.addEventListener("click", () => {
      btn.classList.toggle("active");
      menu.classList.toggle("open");
    });
  });
</script>

<style>
/* ここから CSS */

body {
  margin: 0;
  font-family: "Noto Sans JP", sans-serif;
  background: #f5f5f5;
}

/* ヘッダー */
header
    {position:fixed;        /*画面上部に固定*/
     top:0px;
     left:0px;
     width:100%;            /*帯の長さ*/
     height:80px;           /*ヘッダーの文字下の空間*/
     background-color:#64072A; /*帯の色*/
     color:white;         /*タイトルの文字の色*/ 
     display: flex;                  /* 横並びにする */
     align-items: center;    /* 垂直中央 */
     padding:   0 30px;        /* 上下　左右の余白 */
     box-sizing: border-box; /* widthとpaddingが重なると見切れるからこれで枠内に収める */
     z-index: 1000;          /* 最前面 */
     flex-wrap: wrap; /* ← ここで複数行許可 */}

     .logo /*左側の文字に関する指示*/
      { font-size: 30px;   /* 大きさ調整 */
      font-weight: bold; /* 太字に */
      letter-spacing: 2px; /* 文字の間隔を少し広げる */
      white-space: nowrap; /* ロゴの改行防止 */}

     nav {
      display: flex;
      margin-left: auto;}
      #hidari{
        color:#ffffff;
        text-decoration:none;
        margin-right: 15px;}

      #migi{
        color:#000000;
        text-decoration:none;
        margin-right: 15px;}

      @media (max-width: 700px) /*条件指定できる*/
      {
      header 
      {justify-content: center; /* 中央寄せ */
        height: auto;           /* 高さ自動 */
        }

      nav 
      {width: 100%; /* 2行目に全幅で配置 */
       justify-content: center;
       margin-top: 8px;
      }}

      body{padding-top:40px}

      /*eyecatch*/
      .eyecatch{
        width: 100%;
        height: 600px;
        background-image:url(team.jpg);
        background-size: cover;       /* ← 画面に合わせて拡大縮小（縦横比を維持） */
        background-position: center;  /* ← 画像の中央を基準に表示 */
        background-repeat: no-repeat; /* ← 画像の繰り返しを防ぐ */
      }


/* 見出し */
#subheading h1 {
  margin-left: 20px;
  margin-top: 100px;
  font-size: 2rem;
  font-weight: 600;
  color: #222;
  padding-left: 15px;
  border-left: 5px solid #c9a86a;
}

/* Swiper */
.swiper {
  width: 400px;
  height: 250px;
  margin-left: 15px;
  margin-right: auto;
}

.swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* メンバーカード */
.members-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  max-width: 1000px;
  margin: 40px auto;
}

.member-card {
  background: #fff;
  border-radius: 18px;
  padding: 30px 25px;
  text-align: center;
  box-shadow: 0 8px 25px rgba(0,0,0,0.08);
  transition: 0.3s;
}

.member-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 35px rgba(0,0,0,0.12);
}

.member-photo {
  width: 400px;
  height: 250px;
  object-fit: cover;
  border-radius: 10px;
  margin-bottom: 18px;
}

/* フッター */
footer {
  background-color: #64072A;   /* 背景色 */
  color: #ffffff;              /* 文字色 */
  padding: 20px;               /* 内側余白 */
}

.footer-container {
  display: flex;
  justify-content: space-between; /* 左右に配置 */
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;                /* 中央寄せ */
}

footer nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
}

footer nav ul li {
  margin-left: 20px;
}

footer nav ul li a {
  text-decoration: none;
  color: #ffffff;
  transition: color 0.3s;
}
footer nav ul li a:hover {
  color: #ff9800; /* ホバー時に色が変わる */
}

/* トップへ戻る */
.to-top {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #64072A;
  color: #fff;
  padding: 12px 15px;
  border-radius: 50%;
  text-decoration: none;
  font-size: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.2);
  opacity: 0;
  pointer-events: none;
  transition: 0.3s;
}

.to-top.show {
  opacity: 1;
  pointer-events: auto;
}

.to-top:hover {
  background: #8a0a3c;
}

 /* 歯車ボタン */
  .gear-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
  }

  .gear {
    width: 48px;
    height: 48px;
    color: #dfc0c0;
    transition: transform 0.6s ease;
  }

  /* 開いたら回転 */
  .gear-btn.active .gear {
    transform: rotate(180deg);
  }

  /* ボタン */
  .menu-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    z-index: 1001;
    cursor: pointer;
  }

  .menu-btn img {
    width: 40px;
  }

  /* メニュー本体 */
  .menu {
    position: fixed;
    top: 0;
    right: 0;
    width: 70%;
    height: 80vh;
    background-image: url("/kim_rogo.png"); /* ここを写真パスに変更 */
    background-size: contain;        /* 全体にフィット */
    background-position: center 20%;   /* 中央表示 */
    background-repeat: no-repeat;
    background-color: #ffffff;
    min-height: 100vh;
    color: rgb(5, 33, 12);
    padding: 60px 40px;
    font-size: 200px;
    transform: translateX(100%);
    opacity: 0;
    transition: transform 0.4s ease, opacity 0.4s ease;
    z-index: 1000;
  }
  /* 左側を白くフェード */
.menu::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(255,255,255,0.95) 0%,
    rgba(255,255,255,0.7) 25%,
    rgba(255,255,255,0.3) 45%,
    rgba(255,255,255,0) 65%
  );
  pointer-events: none;
}

  .menu.open {
    transform: translateX(0);
    opacity: 1;
  }

  .menu ul {
    list-style: none;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  .menu li {
    margin-bottom: 24px;
    font-size: 1.2rem;
  }

  /* 背景オーバーレイ */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    z-index: 999;
  }

  .overlay.show {
    opacity: 1;
    pointer-events: auto;
  }
</style>