<!doctype html>
<html>
<head>
<meta charset="UTF-8">
<title>テスト</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
.swiper {
  width: 600px;
  height: 300px;
}
.swiper-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
</style>
</head>

<body>

<div class="swiper hero-swiper">
  <div class="swiper-wrapper">
    <div class="swiper-slide"><img src="activities.jpg"></div>
    <div class="swiper-slide"><img src="contact.jpg"></div>
    <div class="swiper-slide"><img src="governance.jpg"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  // @ts-nocheck
  console.log('JS動いてます');

  const swiper = new Swiper('.hero-swiper', {
    loop: true,
    autoplay: {
      delay: 2000,
    },
  });
</script>

</body>
</html>
